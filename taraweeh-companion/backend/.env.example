# Required: HuggingFace token for Tarteel Whisper ASR
# Get from https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=hf_your_token_here

# Optional: Gemini API key for non-Quran detection (tasbeeh, takbeer)
# Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_key_here

# Dedicated Whisper endpoint (HF Inference Endpoint or Modal)
# HF: https://your-endpoint.us-east-1.aws.endpoints.huggingface.cloud
# Modal: https://your-workspace--your-app.modal.run
WHISPER_ENDPOINT_URL=https://your-endpoint.us-east-1.aws.endpoints.huggingface.cloud

# Optional: expose endpoint lifecycle controls in Settings UI
# true  -> "Wake endpoint" button enabled (calls /api/endpoint/warmup)
# false -> button hidden/disabled
ENDPOINT_ON_DEMAND_ENABLED=false

# Optional: mobile-only deployment mode (enforces phone mic in settings)
MOBILE_ONLY_MODE=false

# Optional: disable startup probe if you don't want lifecycle checks on init
WHISPER_PROBE_ON_INIT=true

# Modal proxy auth (only if your Modal endpoint uses requires_proxy_auth)
# MODAL_KEY=your_modal_key
# MODAL_SECRET=your_modal_secret
USE_LOCAL_WHISPER=false

# Server port (default: 3001)
PORT=3001
