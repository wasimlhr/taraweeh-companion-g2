# ── MentraOS App Credentials ──────────────────────────────────────────────────
# Get these from https://developer.mentraglass.com after registering your app
MENTRA_API_KEY=your_mentra_api_key_here
MENTRA_PACKAGE_NAME=com.taraweehcompanion.mentraos
PORT=3000

# ── Transcription Provider (same as Even G2 backend) ──────────────────────────
# Option A: Groq (recommended — fast, free tier available)
GROQ_API_KEY=your_groq_api_key_here

# Option B: OpenAI Whisper
OPENAI_API_KEY=your_openai_api_key_here

# Option C: Shared server-held keys (sadaka jariya — for public deployment)
SHARED_GROQ_KEY=
SHARED_OPENAI_KEY=

# ── Optional: Dedicated Whisper endpoint (Modal / HuggingFace) ─────────────────
WHISPER_ENDPOINT_URL=
HUGGINGFACE_TOKEN=
MODAL_KEY=
MODAL_SECRET=

# ── Optional: Gemini (alternative transcription provider) ─────────────────────
GEMINI_API_KEY=

# ── App Behaviour ──────────────────────────────────────────────────────────────
# Default surah to start from (1-114, 0 = auto-detect from audio)
DEFAULT_SURAH=0

# Pipeline version: v3 or v4 (v4 recommended)
PIPELINE_VERSION=v4

# Translation language: '' = built-in English, or: en, ur, fr, es, id, tr, bn, zh, ru, sv
TRANSLATION_LANG=

# Display mode: 'arabic' | 'translation' | 'both' (default: both)
DISPLAY_MODE=both
