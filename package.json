{
  "name": "taraweeh-companion",
  "version": "4.3.0",
  "description": "Taraweeh Companion — real-time Quran recitation on Even G2 smart glasses",
  "type": "module",
  "scripts": {
    "postinstall": "cd taraweeh-companion && npm install",
    "start": "cd taraweeh-companion/backend && npm run start",
    "backend:dev": "cd taraweeh-companion/backend && npm run dev",
    "modal:deploy": "powershell -ExecutionPolicy Bypass -File scripts/deploy-modal.ps1",
    "modal:deploy-int8": "powershell -ExecutionPolicy Bypass -File scripts/deploy-modal.ps1 int8",
    "modal:deploy-int4": "powershell -ExecutionPolicy Bypass -File scripts/deploy-modal.ps1 int4",
    "modal:deploy-onnx": "powershell -ExecutionPolicy Bypass -File scripts/deploy-modal.ps1 onnx",
    "qr": "evenhub qr --http --port 3001",
    "qr:url": "evenhub qr --url",
    "qr:railway": "node scripts/qr-web-url.js https://taraweeh.up.railway.app --png",
    "kill-backend": "node scripts/kill-port-3001.js",
    "test-pipeline": "cd taraweeh-companion/backend && node testPipeline.js",
    "sim": "node node_modules/@evenrealities/evenhub-simulator/bin/index.js http://localhost:3001",
    "simulator": "npm run sim",
    "live-monitor": "powershell -ExecutionPolicy Bypass -File scripts/live-monitor.ps1",
    "download-quran-db": "node scripts/download-quran-db.js"
  },
  "dependencies": {
    "@evenrealities/even_hub_sdk": "^0.0.7",
    "dotenv": "^17.3.1",
    "qrcode": "^1.5.4"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@evenrealities/evenhub-cli": "^0.1.5",
    "@evenrealities/evenhub-simulator": "^0.5.0"
  }
}